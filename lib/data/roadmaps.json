      },
      {
        "id": 10,
        "title": "Phase 10: Heap & Sorting",
        "description": "Master heap operations and sorting algorithms for optimization problems.",
        "problems": ["merge-k-sorted-lists", "top-k-frequent-elements", "kth-largest-element-in-an-array", "meeting-rooms-ii", "reorganize-string"]
      },
      {
        "id": 11,
        "title": "Phase 11: Advanced Patterns",
        "description": "Tackle complex problems combining multiple techniques learned so far.",
        "problems": ["word-ladder", "palindrome-partitioning", "generate-parentheses", "permutations", "subsets"]
      }
    ]
