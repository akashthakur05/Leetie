      },
      {
        "id": 5,
        "title": "Phase 5: Trees & Graphs",
        "description": "Master tree traversals (DFS, BFS) and fundamental graph problems.",
        "problems": ["invert-binary-tree", "maximum-depth-of-binary-tree", "same-tree", "subtree-of-another-tree", "lowest-common-ancestor-of-a-binary-search-tree", "number-of-islands", "course-schedule"]
      },
      {
        "id": 6,
        "title": "Phase 6: Binary Search",
        "description": "Learn when and how to apply binary search to problem-solving beyond sorted arrays.",
