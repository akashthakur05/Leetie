{
  "beginner": {
    "id": "beginner",
    "name": "Beginner Roadmap",
    "description": "A structured path for those new to coding interviews. Start with fundamental data structures and build confidence with core patterns.",
    "phases": [
      {
        "id": 1,
        "title": "Phase 1: Arrays & Hash Tables",
        "description": "Learn the two most fundamental data structures. Arrays teach you iteration and indexing; hash tables give you O(1) lookups.",
        "problems": ["contains-duplicate", "two-sum", "find-all-numbers-disappeared-in-an-array", "best-time-to-buy-and-sell-stock", "valid-palindrome", "longest-substring-without-repeating-characters"]
      },
      {
        "id": 2,
        "title": "Phase 2: Two Pointers & Sliding Window",
        "description": "Master pointer manipulation and window expansion/contraction techniques for solving linear problems efficiently.",
